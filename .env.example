# =============================================================================
# HawaiReportApproval - Environment Setup
# -----------------------------------------------------------------------------
# Copy this file to ".env" and adjust the values for your environment:
#     cp .env.example .env        (macOS / Linux)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# Every variable below is loaded by app/config/settings.py at startup.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=HawaiReportApproval
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ── Workflow runtime ─────────────────────────────────────────────────────────
WORKFLOW_TYPE=HawaiReportApproval
# Definition version new instances are pinned to when started.
DEFAULT_DEFINITION_VERSION=1

# ── Reminder / timer scheduler ───────────────────────────────────────────────
REMINDER_ENABLED=true
# How often the reminder worker scans for open human tasks (seconds).
REMINDER_INTERVAL_SECONDS=3600
# Maximum reminders sent per open task before giving up.
REMINDER_MAX_COUNT=3

# ── Security / RBAC ──────────────────────────────────────────────────────────
AUTH_ENABLED=true
# Comma-separated list of users granted administrative privileges
# (publish definitions, reassign tasks, patch workflow state, cancel, migrate).
ADMIN_USERS=admin.user

# ── Persistence ──────────────────────────────────────────────────────────────
# Storage backend for the four separated stores
# (definition / instance / task / audit). Only "memory" is implemented here.
STORE_BACKEND=memory
